{
  "$schema": "https://modelcontextprotocol.io/schema/mcp-config.json",
  "mcpServers": {
    "diagnostics": {
      "type": "http",
      "url": "http://127.0.0.1:3846/mcp",
      "description": "VS Code diagnostics - all 5 tools (errors, warnings, info, health, all diagnostics)"
    }
  },
  "examples": {
    "get_all_diagnostics": {
      "description": "Get all errors and warnings from workspace",
      "tool": "get_all_diagnostics",
      "arguments": {}
    },
    "get_errors_only": {
      "description": "Get only error-level diagnostics",
      "tool": "get_errors",
      "arguments": {}
    },
    "get_file_errors": {
      "description": "Get error-level diagnostics for a specific file",
      "tool": "get_errors",
      "arguments": {
        "filePath": "src/extension.ts"
      }
    },
    "check_health": {
      "description": "Get workspace health score (0-100)",
      "tool": "get_workspace_health",
      "arguments": {}
    }
  }
}
